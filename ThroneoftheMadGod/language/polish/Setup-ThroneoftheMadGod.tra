@3000 = ~Posąg Clangeddina Srebrobrodego~
@3001 = ~Diinkarazan, Wygnany Syn Moradina~
@3002 = ~Wydrążona czaszka olbrzyma, wciąż promieniująca wielkim żarem. Prawdopodobnie regularnie spalano w niej jakieś substancje.~
@3003 = ~Illithidzki bóg Ilsensine wygania Diinkarazana do Otchłani~
@3004 = ~Karlyn Kuldelver, Patriarcha Korolnoru~
@3005 = ~To zdaje się być drugim końcem tuby służącej do komunikacji z wyższymi poziomami.~
@3006 = ~Antracyt zapłonął jasnym płomieniem.~
@3007 = ~„Do dawnej Sali Tronowej Wygnańca”~
@3008 = ~„Diinkarazan, Zdrajca Krasnoludzkich Ideałów”~
@3009 = ~„Diinkarazan, Oskarżony o Uprawianie Niekontrolowanej Magii”~
@3010 = ~„Diinkarazan, Odrzucony Przez Krasnoludzki Panteon”~
@3011 = ~Na ołtarzu położono topór. Drugie zagłębienie pozostaje puste – wygląda na to, że umieszczenie tam kolejnej broni może aktywować mechanizm.~
@3012 = ~Nie możesz używać czaru „Kamienny wzrok” na zewnątrz.~
@3013 = ~Nie możesz użyć tutaj czaru „Kamienny wzrok”.~
@3014 = ~Posąg Kelemvora rozbłyska na chwilę, a tabliczka z symbolem Władcy Umarłych nagle upadła na ziemię.~
@3015 = ~Słyszysz dźwięk metalowych drzwi zamykających się gdzieś powyżej.~
@3016 = ~Metalowe drzwi powyżej zostały ponownie otwarte.~
@3017 = ~Szkoda, że nie rozpoznał innego Zhentarima. Cóż, może był na to zbyt głupi! Nieważne. Spoczywaj w pokoju, chwalebny odszczepieńcze! Ha!~
@3018 = ~Nie mam zamiaru mówić moim szefom o całej tej sprawie. To nic niezwykłego, że Zhentarimowie od czasu do czasu wykańczają się nawzajem, ale nie róbmy afery z jednego trupa.~
@3019 = ~Gdy chwytasz klejnot, rozpada się on w migoczący pył.~ [EFF_E03]
@3020 = ~„Co to za przeklęty hałas? Słyszę tam kogoś!”~
@3021 = ~„Argh. Beznadziejne kreatury.”~
@3022 = ~„Kto tam rozrabia z moimi trollami? Pokaż się!”~
@3023 = ~„Następnego głupca, który mnie zawiedzie, rzucę na pożarcie olbrzymom!”~
@3024 = ~„Natychmiast przestańcie robić ten jazgot, bo sam tam przyjdę!”~
@3025 = ~„Ktoś słono zapłaci za tę zniewagę.”~
@3026 = ~„Przysięgam, że jeśli te trolle mnie zawiodły, to polecą głowy!”~
@3027 = ~„Niech klątwa spadnie na ten przeklęty dzień! Domagam się ciszy!”~
@3028 = ~„Ktokolwiek sieje ten chaos, zapłaci drogo. Słyszycie mnie? SŁYSZYCIE?!”~
@3029 = ~„Kończy mi się cierpliwość!”~
@3030 = ~„Tego hałasu nie da się znieść! Kto majstruje przy moich strażnikach?”~
@3031 = ~„Cóż to za zdrada? Ujawnij się, tchórzu!”~
@3032 = ~„Czy nikt tam na górze nie potrafi wykonać rozkazu? Uciszcie tych intruzów!”~
@3033 = ~„Czy moje polecenia są aż tak trudne? Natychmiast uciszcie intruzów!”~
@3034 = ~„Na kły Vapraka – ktoś odpokutuje za ten rozgardiasz!”~
@3035 = ~Szczurza nora~
@3036 = ~Szalony Bóg został ponownie wygnany.~ 
@3037 = ~Emberon~
@3038 = ~Nudnożuk~
@3039 = ~Możesz beknąć Świętym słowem tylko wtedy, gdy jesteś pod wpływem alkoholu.~  
@3040 = ~Trująca papka~
@3041 = ~Trująca chmura~