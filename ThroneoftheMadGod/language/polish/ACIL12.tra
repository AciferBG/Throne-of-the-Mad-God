@5202 = ~Po co pochhodnnie zzzapalonee? Pochhodnnie parrrzą! Pochhodnnnie rrranią!~
@5203 = ~Urrrsummnogh mmmówił, żże światło potrrzzebne, żżeby mmmali prrrzyjaciele nie wpadli w krrrasnoludzkie pułapki.~
@5204 = ~Czemu nie rrrrozbić pułapek, jak inne krrrasnoludzkie pułapki?~
@5205 = ~Urrrsummnogh mmmówił, że pułapki ważżne, zabijają posszukiwaczzy prrrzygód.~
@5206 = ~Ale pułapki rrranią też nasss!~
@5207 = ~Pułapki nasss nie zzabiją! Trrrolle sssilne! Gadaszzz jak sssłabeussz!~
@5208 = ~SSŁABEUSZ? Ja ci pokażżżę, kto tu jesst sssłabeussz!~
@5209 = ~Csssisza! Tam ssą intruzzzi!~
@5210 = ~Łłłatwo cię załatwić! Maszz miękką elfią ssskórrrę! Rrrozzzerwę ją na częśści!~